# TaskTree 环境变量配置
# 复制此文件为 .env 并修改值

# ========== 后端配置 ==========
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
LOG_LEVEL=info

# ========== 数据库配置 ==========
# SQLite (开发环境推荐)
DATABASE_URL=sqlite+aiosqlite:///./data/tasktree.db

# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tasktree

# ========== LLM 大模型配置 (AI 功能必需) ==========
# 支持的提供商: minimax, openai, anthropic
LLM_PROVIDER=minimax
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=MiniMax-M2.7

# Minimax 专用 (可选)
LLM_GROUP_ID=your-group-id

# ========== 钉钉Stream模式配置 (可选) ==========
# 启用钉钉Stream模式（本地开发环境推荐）
DINGTALK_STREAM_ENABLED=false
# 钉钉应用凭证
DINGTALK_CLIENT_ID=your-dingtalk-app-key
DINGTALK_CLIENT_SECRET=your-dingtalk-app-secret

# ========== Docker 部署配置 ==========
# 前端端口
FRONTEND_PORT=80
# 后端端口
BACKEND_PORT=8000
# 时区
TZ=Asia/Shanghai