# TaskTree 环境变量配置
# 复制此文件为 .env 并修改值

# 后端配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false

# 数据库 (SQLite 文件路径)
DATABASE_URL=sqlite+aiosqlite:///./data/tasktree.db

# LLM 大模型配置 (AI 功能必需)
# 支持的提供商: minimax, openai, anthropic
LLM_PROVIDER=minimax
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=MiniMax-M2.7
# Minimax 专用 (可选)
LLM_GROUP_ID=your-group-id